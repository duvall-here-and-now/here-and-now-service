# Here and Now Service - Environment Variables
# Copy this file to .env and fill in the values

# Required: Application port
PORT=6060

# Required: Frontend URL for CORS (comma-separated for multiple origins)
CLIENT_ORIGIN_URL=http://localhost:3000

# Required: Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=your-api-identifier

# Azure Cosmos DB Configuration
# If not configured, the service will use in-memory storage (data lost on restart)
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_PRIMARY_KEY=your-primary-key
COSMOS_DATABASE_NAME=HereAndNow
COSMOS_CONTAINER_NAME=Reminders
