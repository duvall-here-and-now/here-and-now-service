# Production Environment Variables for Azure App Service
# These should be configured in Azure Portal under Configuration > Application settings

# Port (Azure automatically sets this to 8080 or 80)
PORT=8080

# Client Origin URL (your Azure Static Web App URL)
CLIENT_ORIGIN_URL=https://<your-static-web-app-url>.azurestaticapps.net

# Auth0 Configuration (same as development)
AUTH0_DOMAIN=dev-147y58ln2o1c6q2v.us.auth0.com
AUTH0_AUDIENCE=https://hello-world.example.com

# Note: In Azure App Service, these will be set as Application Settings
# Do NOT commit actual .env files to git - use Azure Configuration
